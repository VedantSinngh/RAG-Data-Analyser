# App Config
APP_ENV=development
SECRET_KEY=dev_secret_key_change_in_production
FRONTEND_URL=http://localhost:3000

# Database (Postgres container hostname in Docker Compose is 'postgres')
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/analystai

# Groq API Config (Get key from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace API Config (For semantic embeddings, optional)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenAI API config (Alternative to Groq)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB Config
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION_NAME=analystai_docs
